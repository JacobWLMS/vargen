{
  "name": "txt2img + Upscale",
  "description": "Generate then upscale 2x with RealESRGAN",
  "nodes": {
    "checkpoint": {
      "type": "load_checkpoint",
      "widgets": { "checkpoint": "" },
      "x": 50, "y": 150
    },
    "positive": {
      "type": "clip_text_encode",
      "widgets": { "text": "a beautiful photograph, professional lighting, 8k resolution" },
      "x": 320, "y": 50
    },
    "negative": {
      "type": "clip_text_encode",
      "widgets": { "text": "blurry, distorted, deformed, low quality, watermark" },
      "x": 320, "y": 230
    },
    "latent": {
      "type": "empty_latent",
      "widgets": { "width": 1024, "height": 1024, "batch_size": 1 },
      "x": 320, "y": 400
    },
    "sampler": {
      "type": "ksampler",
      "widgets": { "seed": -1, "steps": 20, "cfg": 7.0, "sampler": "euler", "scheduler": "normal", "denoise": 1.0 },
      "x": 620, "y": 150
    },
    "upscale_model": {
      "type": "load_upscale_model",
      "widgets": { "model": "" },
      "x": 620, "y": 420
    },
    "upscale": {
      "type": "upscale_with_model",
      "widgets": {},
      "x": 900, "y": 200
    },
    "save": {
      "type": "save_image",
      "widgets": { "filename_prefix": "upscaled" },
      "x": 1150, "y": 200
    }
  },
  "edges": [
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "positive", "to_port": "CLIP" },
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "negative", "to_port": "CLIP" },
    { "from_node": "checkpoint", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "positive", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "POSITIVE" },
    { "from_node": "negative", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "NEGATIVE" },
    { "from_node": "latent", "from_port": "LATENT", "to_node": "sampler", "to_port": "LATENT" },
    { "from_node": "sampler", "from_port": "IMAGE", "to_node": "upscale", "to_port": "IMAGE" },
    { "from_node": "upscale_model", "from_port": "UPSCALE_MODEL", "to_node": "upscale", "to_port": "UPSCALE_MODEL" },
    { "from_node": "upscale", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
