{
  "name": "SDXL img2img + Upscale",
  "description": "Transform an image with SDXL then upscale 2x",
  "nodes": {
    "checkpoint": {
      "type": "load_checkpoint",
      "widgets": { "checkpoint": "" },
      "x": 50, "y": 150
    },
    "load_img": {
      "type": "load_image",
      "widgets": {},
      "x": 50, "y": 420
    },
    "positive": {
      "type": "clip_text_encode",
      "widgets": { "text": "professional photograph, detailed, high quality" },
      "x": 320, "y": 50
    },
    "negative": {
      "type": "clip_text_encode",
      "widgets": { "text": "blurry, distorted, deformed, low quality" },
      "x": 320, "y": 250
    },
    "sampler": {
      "type": "ksampler",
      "widgets": { "seed": -1, "steps": 20, "cfg": 7.0, "sampler": "euler", "scheduler": "normal", "denoise": 0.65 },
      "x": 620, "y": 150
    },
    "vae_decode": {
      "type": "vae_decode",
      "widgets": {},
      "x": 900, "y": 200
    },
    "upscale_loader": {
      "type": "load_upscale_model",
      "widgets": { "model": "" },
      "x": 900, "y": 400
    },
    "upscale": {
      "type": "upscale_with_model",
      "widgets": {},
      "x": 1150, "y": 250
    },
    "save": {
      "type": "save_image",
      "widgets": { "filename_prefix": "img2img_upscaled" },
      "x": 1400, "y": 250
    }
  },
  "edges": [
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "positive", "to_port": "CLIP" },
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "negative", "to_port": "CLIP" },
    { "from_node": "checkpoint", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "positive", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "POSITIVE" },
    { "from_node": "negative", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "NEGATIVE" },
    { "from_node": "load_img", "from_port": "IMAGE", "to_node": "sampler", "to_port": "IMAGE" },
    { "from_node": "checkpoint", "from_port": "VAE", "to_node": "vae_decode", "to_port": "VAE" },
    { "from_node": "sampler", "from_port": "LATENT", "to_node": "vae_decode", "to_port": "LATENT" },
    { "from_node": "vae_decode", "from_port": "IMAGE", "to_node": "upscale", "to_port": "IMAGE" },
    { "from_node": "upscale_loader", "from_port": "UPSCALE_MODEL", "to_node": "upscale", "to_port": "UPSCALE_MODEL" },
    { "from_node": "upscale", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
}
