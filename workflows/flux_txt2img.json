{
  "name": "FLUX txt2img",
  "description": "FLUX.1-dev text to image — select any FLUX checkpoint (GGUF, safetensors)",
  "nodes": {
    "checkpoint": {
      "type": "load_checkpoint",
      "widgets": { "checkpoint": "" },
      "x": 50, "y": 200
    },
    "sampler": {
      "type": "flux_sampler",
      "widgets": { "prompt": "a beautiful photograph of a landscape, golden hour, 8k", "seed": -1, "steps": 20, "guidance": 3.5, "width": 1024, "height": 1024, "max_sequence_length": 512 },
      "x": 400, "y": 150
    },
    "save": {
      "type": "save_image",
      "widgets": { "filename_prefix": "flux" },
      "x": 730, "y": 200
    }
  },
  "edges": [
    { "from_node": "checkpoint", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "sampler", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
}
