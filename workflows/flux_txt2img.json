{
  "name": "FLUX txt2img",
  "description": "FLUX.1-dev text to image — uses FLUX Sampler (no separate VAE decode needed)",
  "nodes": {
    "flux": {
      "type": "load_flux",
      "widgets": { "model": "" },
      "x": 50, "y": 200
    },
    "sampler": {
      "type": "flux_sampler",
      "widgets": { "seed": -1, "steps": 20, "guidance": 3.5, "width": 1024, "height": 1024 },
      "x": 400, "y": 200
    },
    "save": {
      "type": "save_image",
      "widgets": { "filename_prefix": "flux" },
      "x": 730, "y": 200
    }
  },
  "edges": [
    { "from_node": "flux", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "sampler", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
}
