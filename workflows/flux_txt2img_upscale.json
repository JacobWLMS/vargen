{
  "name": "FLUX txt2img + Upscale",
  "description": "FLUX generation followed by RealESRGAN 2x upscale",
  "nodes": {
    "flux": {
      "type": "load_flux",
      "widgets": { "model": "" },
      "x": 50, "y": 200
    },
    "sampler": {
      "type": "flux_sampler",
      "widgets": { "seed": -1, "steps": 20, "guidance": 3.5, "width": 1024, "height": 1024 },
      "x": 400, "y": 200
    },
    "upscale_model": {
      "type": "load_upscale_model",
      "widgets": { "model": "" },
      "x": 400, "y": 420
    },
    "upscale": {
      "type": "upscale_with_model",
      "widgets": {},
      "x": 730, "y": 250
    },
    "save": {
      "type": "save_image",
      "widgets": { "filename_prefix": "flux_upscaled" },
      "x": 1000, "y": 250
    }
  },
  "edges": [
    { "from_node": "flux", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "sampler", "from_port": "IMAGE", "to_node": "upscale", "to_port": "IMAGE" },
    { "from_node": "upscale_model", "from_port": "UPSCALE_MODEL", "to_node": "upscale", "to_port": "UPSCALE_MODEL" },
    { "from_node": "upscale", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
}
