{
  "name": "ControlNet Canny",
  "description": "Edge-guided generation — load image, detect edges, generate with ControlNet",
  "nodes": {
    "checkpoint": { "type": "load_checkpoint", "widgets": { "checkpoint": "" }, "x": 50, "y": 150 },
    "load_cn": { "type": "load_controlnet", "widgets": { "model": "" }, "x": 50, "y": 380 },
    "load_img": { "type": "load_image", "widgets": {}, "x": 50, "y": 550 },
    "canny": { "type": "canny_edge", "widgets": { "low_threshold": 100, "high_threshold": 200 }, "x": 320, "y": 550 },
    "apply_cn": { "type": "apply_controlnet", "widgets": { "strength": 0.8, "start_percent": 0.0, "end_percent": 1.0 }, "x": 320, "y": 300 },
    "positive": { "type": "clip_text_encode", "widgets": { "text": "a detailed photograph" }, "x": 600, "y": 80 },
    "negative": { "type": "clip_text_encode", "widgets": { "text": "blurry, distorted" }, "x": 600, "y": 260 },
    "latent": { "type": "empty_latent", "widgets": { "width": 1024, "height": 1024, "batch_size": 1 }, "x": 600, "y": 430 },
    "sampler": { "type": "ksampler", "widgets": { "seed": -1, "steps": 20, "cfg": 7.0, "sampler": "euler", "scheduler": "normal", "denoise": 1.0 }, "x": 880, "y": 200 },
    "vae_decode": { "type": "vae_decode", "widgets": {}, "x": 1150, "y": 250 },
    "save": { "type": "save_image", "widgets": { "filename_prefix": "controlnet" }, "x": 1370, "y": 250 }
  },
  "edges": [
    { "from_node": "checkpoint", "from_port": "MODEL", "to_node": "apply_cn", "to_port": "MODEL" },
    { "from_node": "load_cn", "from_port": "CONTROLNET", "to_node": "apply_cn", "to_port": "CONTROLNET" },
    { "from_node": "load_img", "from_port": "IMAGE", "to_node": "canny", "to_port": "IMAGE" },
    { "from_node": "canny", "from_port": "IMAGE", "to_node": "apply_cn", "to_port": "IMAGE" },
    { "from_node": "apply_cn", "from_port": "MODEL", "to_node": "sampler", "to_port": "MODEL" },
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "positive", "to_port": "CLIP" },
    { "from_node": "checkpoint", "from_port": "CLIP", "to_node": "negative", "to_port": "CLIP" },
    { "from_node": "positive", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "POSITIVE" },
    { "from_node": "negative", "from_port": "CONDITIONING", "to_node": "sampler", "to_port": "NEGATIVE" },
    { "from_node": "latent", "from_port": "LATENT", "to_node": "sampler", "to_port": "LATENT" },
    { "from_node": "checkpoint", "from_port": "VAE", "to_node": "vae_decode", "to_port": "VAE" },
    { "from_node": "sampler", "from_port": "LATENT", "to_node": "vae_decode", "to_port": "LATENT" },
    { "from_node": "vae_decode", "from_port": "IMAGE", "to_node": "save", "to_port": "IMAGE" }
  ]
}
